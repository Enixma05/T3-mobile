<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Warna background dalam -->
    <solid android:color="#E7E8F3"/>

    <!-- Border putus-putus -->
    <stroke
        android:width="1dp"
        android:color="#5C6BC0"
        android:dashWidth="4dp"
        android:dashGap="2dp"/>

    <!-- Sudut rounded -->
    <corners android:radius="5dp"/>

    <!-- Padding dalam (opsional, biar isi tidak nempel ke border) -->
    <padding
        android:left="12dp"
        android:top="2dp"
        android:right="12dp"
        android:bottom="2dp"/>

</shape>